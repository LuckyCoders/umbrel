#!/usr/bin/env bash

set -euo pipefail

# umbrelOS on Raspberry Pi boots from an SD card. When both the SD card (system +
# Umbrel data) and an external USB drive are present, Umbrel always runs from the
# SD card. External drives must never be auto-formatted at boot.
#
# Normal USB drives (media, backups, etc.) are mounted by umbreld under Files → External.

check_root () {
  if [[ $UID != 0 ]]; then
    echo "This script must be run as root"
    exit 1
  fi
}

running_off_sdcard() {
  if df -h | grep --silent /dev/mmcblk0
  then
    echo "true"
  else
    echo "false"
  fi
}

main () {
  echo "Running external storage mount script..."
  check_root

  if [[ "$(running_off_sdcard)" == "false" ]]
  then
    echo "This script should only run when umbrelOS boots from an SD card, exiting..."
    exit
  fi

  echo "umbrelOS is running from the SD card; Umbrel data stays on the SD card."
  echo "External USB drives are not formatted at boot and are mounted by umbreld under Files → External."

  # Check if device is running with uas driver, if so blacklist it and reboot
  echo "Checking if we need to blacklist UAS"
  blacklist_uas_output=$(umbreld blacklist-uas || true)
  if [[ "${blacklist_uas_output}" == *"mount-script-halt"* ]]; then
    echo "UAS was blacklisted and device is rebooting, exiting"
    return
  fi

  exit 0
}

main
